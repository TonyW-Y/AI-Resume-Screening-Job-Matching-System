#!/bin/bash

echo "=== POST BUILD: Fixing dependencies ==="

# Force uninstall HF's forced versions
pip uninstall -y gradio huggingface-hub gradio-client || true

# Install compatible versions
pip install --no-cache-dir huggingface_hub==0.23.5 gradio==4.44.0

# Verify installations
python -c "import gradio; print(f'Gradio version: {gradio.__version__}')"
python -c "import huggingface_hub; print(f'HF Hub version: {huggingface_hub.__version__}')"

echo "=== POST BUILD: Complete ==="